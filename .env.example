# ===== DATABASE =====
# Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@ep-example.neon.tech/dbname?sslmode=require

# ===== WEB3 & BLOCKCHAIN =====
# BIP39 mnemonic seed phrase (12-24 words) for HD wallet generation
MNEMONIC_SEED=abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon about

# Main merchant wallet address (where payments are received)
MAIN_WALLET_ADDRESS=0x1234567890123456789012345678901234567890

# Main wallet private key (for gas distribution)
# IMPORTANT: Never commit this to version control!
PRIVATE_KEY=0x1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef

# ===== SECURITY & ENCRYPTION =====
# API secret for rate limiting and internal validation
API_SECRET=your-super-secret-api-key-change-this

# Webhook trigger secret (used by cron jobs)
WEBHOOK_TRIGGER_SECRET=your-webhook-trigger-secret-change-this

# Encryption key for storing sensitive data (must be 32+ chars)
ENCRYPTION_KEY=your-encryption-key-minimum-32-characters-long

# JWT secret for session management
JWT_SECRET=your-jwt-secret-key-change-this

# ===== APPLICATION =====
# Application URL (used for webhook callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron job authorization secret
CRON_SECRET=your-cron-secret-key-change-this

# ===== OPTIONAL: BSC RPC CONFIGURATION =====
# Custom BSC RPC endpoint (defaults to public endpoint)
# BSC_RPC_URL=https://bsc-dataseed1.binance.org:8545

# ===== OPTIONAL: EMAIL/NOTIFICATIONS =====
# SENDGRID_API_KEY=your-sendgrid-key-for-emails
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# ===== OPTIONAL: ANALYTICS =====
# VERCEL_ANALYTICS_ID=your-vercel-analytics-id
# POSTHOG_API_KEY=your-posthog-key
